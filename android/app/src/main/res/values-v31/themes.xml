<?xml version="1.0" encoding="utf-8"?>
<!--
    API 31+ (Android 12+) splash screen overrides.
    Only shows the app icon centered on black background.
    Branding text removed — it was glitched (A flipped, u cut off).
    The icon alone is sufficient for the splash screen identity.
-->
<resources>
    <style name="Theme.OTAku.Splash" parent="Theme.SplashScreen">
        <!-- Black background matching the launcher icon -->
        <item name="windowSplashScreenBackground">#000000</item>
        <!-- The icon shown during splash — uses the launcher icon foreground -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <!-- Icon background color (circular mask behind the icon) -->
        <item name="windowSplashScreenIconBackgroundColor">#000000</item>
        <!-- After splash, transition to the main OTAku theme -->
        <item name="postSplashScreenTheme">@style/Theme.OTAku</item>
    </style>
</resources>
