<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Dark mode overrides for utility colors.
        Theme color attributes (colorSurface, etc.) are handled via
        values-night/themes.xml inheriting Theme.OTAku.Dark.
    -->

    <!-- Chip backgrounds -->
    <color name="chip_selected_bg">#00382E</color>
    <color name="chip_default_bg">#2C2C2C</color>

    <!-- Card borders -->
    <color name="card_border">#3F4944</color>

    <!-- Partition list text dark override (near-white on dark surface) -->
    <color name="partition_text">#E1E3E0</color>

    <!-- Log output dark theme overrides — dark bg + light text -->
    <color name="log_background">#1E1E1E</color>
    <color name="log_text">#D4D4D4</color>
    <color name="log_divider">#333333</color>
</resources>
