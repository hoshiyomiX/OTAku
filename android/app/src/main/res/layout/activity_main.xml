<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml — OTAku

    Single-purpose: Build partition images (.img) into flashable OTA ZIP.

    Layout (single scroll architecture):
    ┌─────────────────────────────────────────┐
    │ TopAppBar (title + version + theme btn) │
    ├─────────────────────────────────────────┤
    │ NestedScrollView (full height)          │
    │   Settings Card                         │
    │     Device / Partitions / Compression   │
    │     Level / Output                      │
    │   [BUILD OTA NOW] + ProgressBar         │
    │   Log Card (below Build button)         │
    │     Header + Copy/Clear + ScrollView    │
    └─────────────────────────────────────────┘
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/app_name"
            app:subtitle="@string/toolbar_subtitle"
            app:titleTextColor="?attr/colorOnSurface"
            app:subtitleTextColor="?attr/colorOnSurfaceVariant"
            app:menu="@menu/toolbar_menu"
            style="@style/Widget.OTAku.Toolbar" />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Scrollable Settings + Build Button + Log Panel      -->
        <!-- Full height scroll — logs placed below Build button -->
        <!-- ═══════════════════════════════════════════════════ -->

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollViewSettings"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="vertical"
            android:fadeScrollbars="true"
            android:scrollbarThumbVertical="@android:color/darker_gray"
            android:scrollbarSize="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="16dp">

                <!-- ═══════════════════════════════════════ -->
                <!-- Unified Settings Card                    -->
                <!-- ═══════════════════════════════════════ -->

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutlineVariant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- ── 0. Flashable Information ── -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Flashable Information"
                            style="@style/TextAppearance.OTAku.SectionTitle"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="ROM name and maker (cosmetic — shown in flasher banner)"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginBottom="4dp" />

                        <!-- ROM name + Maker (vertical stack) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="2dp">

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/layoutRomName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="ROM name"
                                app:boxBackgroundColor="?attr/colorSurface"
                                app:boxCornerRadiusTopStart="12dp"
                                app:boxCornerRadiusTopEnd="12dp"
                                app:boxCornerRadiusBottomStart="12dp"
                                app:boxCornerRadiusBottomEnd="12dp"
                                app:boxStrokeWidth="1dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/editTextRomName"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="text"
                                    android:maxLines="1"
                                    android:textSize="14sp"
                                    android:gravity="center_vertical"
                                    android:paddingTop="10dp"
                                    android:paddingBottom="10dp" />

                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/layoutMaker"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Maker"
                                android:layout_marginTop="8dp"
                                app:boxBackgroundColor="?attr/colorSurface"
                                app:boxCornerRadiusTopStart="12dp"
                                app:boxCornerRadiusTopEnd="12dp"
                                app:boxCornerRadiusBottomStart="12dp"
                                app:boxCornerRadiusBottomEnd="12dp"
                                app:boxStrokeWidth="1dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/editTextMaker"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="text"
                                    android:maxLines="1"
                                    android:textSize="14sp"
                                    android:gravity="center_vertical"
                                    android:paddingTop="10dp"
                                    android:paddingBottom="10dp" />

                            </com.google.android.material.textfield.TextInputLayout>

                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Optional — leave blank for default banner"
                            style="@style/TextAppearance.OTAku.Micro"
                            android:layout_marginStart="4dp"
                            android:layout_marginBottom="4dp" />

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="?attr/colorOutlineVariant"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="14dp" />

                        <!-- ── 1. Device ── -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/label_device"
                                style="@style/TextAppearance.OTAku.SectionTitle" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/description_device"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginBottom="8dp" />

                        <!--
                            Device codename input + Auto-Detect button (horizontal layout).
                            Input takes maximum width (weight=1), button has text + icon.
                            Original sizing restored — the icon-only button was too small
                            and hid the "Auto-Detect" label.
                        -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="2dp">

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/layoutDevice"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="@string/hint_device_codename"
                                android:layout_gravity="center_vertical"
                                app:boxBackgroundColor="?attr/colorSurface"
                                app:boxCornerRadiusTopStart="12dp"
                                app:boxCornerRadiusTopEnd="12dp"
                                app:boxCornerRadiusBottomStart="12dp"
                                app:boxCornerRadiusBottomEnd="12dp"
                                app:boxStrokeWidth="1dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/editTextDevice"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="text"
                                    android:maxLines="1"
                                    android:textSize="14sp"
                                    android:gravity="center_vertical"
                                    android:paddingTop="10dp"
                                    android:paddingBottom="10dp" />

                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/buttonAutoDetect"
                                style="Widget.Material3.Button.TonalButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:layout_marginStart="8dp"
                                android:text="@string/button_auto_detect"
                                android:textSize="12sp"
                                android:minWidth="0dp"
                                android:paddingHorizontal="12dp"
                                app:icon="@drawable/ic_auto_detect"
                                app:iconSize="16dp"
                                app:iconPadding="4dp"
                                app:cornerRadius="12dp" />

                        </LinearLayout>

                        <!-- Helper text below the input (smaller, uses Micro caption style) -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/helper_device_codename"
                            style="@style/TextAppearance.OTAku.Micro"
                            android:layout_marginStart="4dp"
                            android:layout_marginBottom="4dp" />

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="?attr/colorOutlineVariant"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="14dp" />

                        <!-- ── 2. Add Partitions ── -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_partitions"
                            style="@style/TextAppearance.OTAku.SectionTitle"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/textEmptyHint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/hint_add_images_prompt"
                            android:textSize="13sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginBottom="10dp"
                            android:visibility="visible" />

                        <!-- Add Images + Remove All -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/buttonAddImages"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/button_add_images"
                                style="Widget.Material3.Button.TonalButton"
                                app:icon="@android:drawable/ic_input_add"
                                app:iconGravity="textStart" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/buttonRemoveAll"
                                style="Widget.Material3.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/button_remove_all"
                                android:visibility="gone"
                                android:layout_marginStart="8dp" />

                        </LinearLayout>

                        <!-- Image list container (populated programmatically) -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="?attr/colorOutlineVariant"
                            app:cardBackgroundColor="?attr/colorSurface">

                            <LinearLayout
                                android:id="@+id/containerImageList"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="8dp"
                                android:minHeight="48dp" />

                        </com.google.android.material.card.MaterialCardView>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="?attr/colorOutlineVariant"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="14dp" />

                        <!-- ── 3. Compression Format ── -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_compression"
                            style="@style/TextAppearance.OTAku.SectionTitle"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/description_compression"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginBottom="8dp" />

                        <androidx.appcompat.widget.AppCompatSpinner
                            android:id="@+id/spinnerCompression"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="?attr/selectableItemBackground"
                            android:spinnerMode="dropdown"
                            android:paddingStart="4dp"
                            android:paddingEnd="8dp" />

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="?attr/colorOutlineVariant"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="14dp" />

                        <!-- ── 4. Compression Level ── -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_compression_level"
                            style="@style/TextAppearance.OTAku.SectionTitle"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/description_compression_level"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginBottom="8dp" />

                        <androidx.appcompat.widget.AppCompatSpinner
                            android:id="@+id/spinnerCompressionLevel"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="?attr/selectableItemBackground"
                            android:spinnerMode="dropdown"
                            android:paddingStart="4dp"
                            android:paddingEnd="8dp" />

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="?attr/colorOutlineVariant"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="14dp" />

                        <!-- ── 5. Output ── -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_output"
                            style="@style/TextAppearance.OTAku.SectionTitle"
                            android:layout_marginBottom="6dp" />

                        <!-- Custom filename input -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/layoutCustomFilename"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:hint="@string/hint_custom_filename"
                            app:boxBackgroundColor="?attr/colorSurface"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:helperText="@string/helper_custom_filename"
                            app:helperTextEnabled="true"
                            app:helperTextTextAppearance="@style/TextAppearance.OTAku.Micro"
                            app:counterEnabled="true"
                            app:counterMaxLength="128"
                            app:counterTextAppearance="@style/TextAppearance.OTAku.Micro">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/editTextCustomFilename"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:maxLines="1"
                                android:textSize="14sp"
                                android:maxLength="128" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Output filename preview — italic filename, non-italic "Preview:" label -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp"
                            android:paddingStart="4dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_preview"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginEnd="6dp" />

                            <TextView
                                android:id="@+id/textPreviewFilename"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textStyle="italic"
                                android:maxLines="2"
                                android:ellipsize="middle"
                                android:fontFamily="monospace" />

                        </LinearLayout>

                        <!-- Output directory + Browse -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="16dp">

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="8dp"
                                app:boxBackgroundColor="?attr/colorSurface"
                                app:boxCornerRadiusTopStart="12dp"
                                app:boxCornerRadiusTopEnd="12dp"
                                app:boxCornerRadiusBottomStart="12dp"
                                app:boxCornerRadiusBottomEnd="12dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/editTextOutput"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="@string/hint_output_dir"
                                    android:inputType="none"
                                    android:focusable="false"
                                    android:clickable="false"
                                    android:maxLines="2"
                                    android:ellipsize="middle"
                                    android:textSize="14sp" />

                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/buttonBrowseOutput"
                                style="Widget.Material3.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/button_browse"
                                android:minWidth="80dp" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ═══════════════════════════════════════════════════ -->
                <!-- Progress Bar (build button moved to FAB)               -->
                <!-- ═══════════════════════════════════════════════════ -->

                <!-- Per-partition progress bars + labels (built programmatically) -->
                <LinearLayout
                    android:id="@+id/progressBarContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="10dp" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Standalone Log Panel — outside NestedScrollView       -->
        <!--                                                       -->
        <!-- Sits below the settings scroll area as a sibling,      -->
        <!-- NOT inside it. This means the log panel is always      -->
        <!-- visible at the bottom of the screen and scrolls        -->
        <!-- independently from the settings above. The settings    -->
        <!-- NestedScrollView has weight=1 (flexible), this log     -->
        <!-- card has weight=1 (takes ~50% of screen height).       -->
        <!-- ═══════════════════════════════════════════════════ -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/logCard"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:cardBackgroundColor="@android:color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- Log header bar — clickable + swipeable to toggle expand/collapse -->
                <LinearLayout
                    android:id="@+id/logHeaderBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <!-- Arrow toggle — LEFT of "Logs" text.
                         Plain ImageView with ?attr/colorPrimary tint for accent color.
                         Click handled by parent logHeaderBar (full-width clickable). -->
                    <ImageView
                        android:id="@+id/buttonToggleLog"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_expand_log"
                        android:contentDescription="@string/label_output_log"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="?attr/colorPrimary"
                        android:scaleType="centerInside"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_output_log"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:textColor="?attr/colorPrimary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonCopyLog"
                        style="Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="@string/button_copy_log"
                        android:textSize="12sp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonClearLog"
                        style="Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="@string/button_clear_log"
                        android:textSize="12sp"
                        android:minWidth="0dp"
                        android:layout_marginStart="4dp"
                        android:paddingHorizontal="8dp" />

                </LinearLayout>

                <!-- Log divider -->
                <View
                    android:id="@+id/logDivider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/log_divider" />

                <!-- Standalone scrollable log — visibility toggled by header click.
                     When collapsed (GONE), the log card shrinks to just the header bar,
                     giving the settings NestedScrollView more space. -->
                <ScrollView
                    android:id="@+id/scrollViewLog"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:fillViewport="true"
                    android:scrollbars="vertical"
                    android:fadeScrollbars="true"
                    android:scrollbarThumbVertical="@android:color/darker_gray"
                    android:scrollbarSize="4dp">

                    <TextView
                        android:id="@+id/textViewLog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:textColor="?attr/colorPrimary"
                        android:fontFamily="monospace"
                        android:textSize="11sp"
                        android:lineSpacingMultiplier="1.3"
                        android:typeface="monospace"
                        android:textIsSelectable="true" />

                </ScrollView>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- Mini floating logs header — shown ONLY when logCard    -->
    <!-- is collapsed. Positioned at bottom|start to mirror the  -->
    <!-- Build OTA FAB at bottom|end.                            -->
    <!--                                                         -->
    <!-- Contains only: arrow icon + "Logs" text.                -->
    <!-- Tap to expand the log panel back.                       -->
    <!-- ═══════════════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/miniLogHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="?attr/colorPrimary">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp">

            <ImageView
                android:id="@+id/miniToggleArrow"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_expand_log"
                android:contentDescription="@string/label_output_log"
                app:tint="?attr/colorOnPrimary"
                android:scaleType="centerInside"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_output_log"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:textColor="?attr/colorOnPrimary" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- Floating Action Button — Build OTA Now                 -->
    <!-- Appears at bottom-right, enabled only when all          -->
    <!-- required fields are filled (partitions + codename).     -->
    <!-- ═══════════════════════════════════════════════════ -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/buttonExecute"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:text="@string/button_repack"
        android:contentDescription="@string/button_repack"
        app:icon="@android:drawable/ic_media_play"
        android:enabled="false" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
