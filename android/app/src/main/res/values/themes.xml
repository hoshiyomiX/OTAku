<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Theme definitions for OTAku.
        Material Design 3 (Material You) with teal/green color scheme.
    -->

    <!-- Splash screen theme — shows OTAku icon on black background at launch.
         Uses AndroidX SplashScreen API (compatible back to API 23).
         The icon (ic_launcher_foreground) is displayed centered with
         the iconBackground color behind it in a circular mask.
         Splash duration is set to 2 seconds in MainActivity.kt.
         No branding text — icon alone provides splash identity. -->
    <style name="Theme.OTAku.Splash" parent="Theme.SplashScreen">
        <!-- Black background matching the launcher icon -->
        <item name="windowSplashScreenBackground">#000000</item>
        <!-- The icon shown during splash — uses the same foreground as the launcher icon -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <!-- Icon background color (circular mask behind the icon) -->
        <item name="windowSplashScreenIconBackgroundColor">#000000</item>
        <!-- Branding text removed — was glitched (A letter flipped, u cut off).
             The icon alone is sufficient for splash screen identity.
             See values-v31/themes.xml for API 31+ specific overrides. -->
        <!-- After splash, transition to the main OTAku theme -->
        <item name="postSplashScreenTheme">@style/Theme.OTAku</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- Base application theme (light)                                -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <style name="Theme.OTAku" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_light_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_light_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_light_onSecondaryContainer</item>

        <!-- Tertiary color -->
        <item name="colorTertiary">@color/md_theme_light_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_light_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_light_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_light_onTertiaryContainer</item>

        <!-- Error color -->
        <item name="colorError">@color/md_theme_light_error</item>
        <item name="colorOnError">@color/md_theme_light_onError</item>
        <item name="colorErrorContainer">@color/md_theme_light_errorContainer</item>
        <item name="colorOnErrorContainer">@color/md_theme_light_onErrorContainer</item>

        <!-- Background and surface -->
        <item name="android:colorBackground">@color/md_theme_light_background</item>
        <item name="colorOnBackground">@color/md_theme_light_onBackground</item>
        <item name="colorSurface">@color/md_theme_light_surface</item>
        <item name="colorOnSurface">@color/md_theme_light_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_light_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_light_onSurfaceVariant</item>

        <!-- Outline -->
        <item name="colorOutline">@color/md_theme_light_outline</item>
        <item name="colorOutlineVariant">@color/md_theme_light_outlineVariant</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Text appearance -->
        <item name="android:textColorPrimary">@color/md_theme_light_onSurface</item>
        <item name="android:textColorSecondary">@color/md_theme_light_onSurfaceVariant</item>

        <!-- Material components -->
        <item name="toolbarStyle">@style/Widget.OTAku.Toolbar</item>
        <item name="chipStyle">@style/Widget.OTAku.Chip</item>
        <item name="materialButtonStyle">@style/Widget.OTAku.Button</item>

        <!-- Toolbar icon tinting -->
        <item name="colorControlNormal">@color/md_theme_light_onSurface</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- Suisei Blue fallback theme (light)                            -->
    <!--                                                               -->
    <!-- Used on Android 8.0-11 (API 26-30) when Material You is not    -->
    <!-- available, or when the user has explicitly disabled dynamic    -->
    <!-- color. Base color #00B0F0 (Hoshimachi Suisei signature blue).  -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <style name="Theme.OTAku.Suisei" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/suisei_light_primary</item>
        <item name="colorOnPrimary">@color/suisei_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/suisei_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/suisei_light_onPrimaryContainer</item>

        <item name="colorSecondary">@color/suisei_light_secondary</item>
        <item name="colorOnSecondary">@color/suisei_light_onSecondary</item>
        <item name="colorSecondaryContainer">@color/suisei_light_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/suisei_light_onSecondaryContainer</item>

        <item name="colorTertiary">@color/suisei_light_tertiary</item>
        <item name="colorOnTertiary">@color/suisei_light_onTertiary</item>
        <item name="colorTertiaryContainer">@color/suisei_light_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/suisei_light_onTertiaryContainer</item>

        <item name="colorError">@color/suisei_light_error</item>
        <item name="colorOnError">@color/suisei_light_onError</item>
        <item name="colorErrorContainer">@color/suisei_light_errorContainer</item>
        <item name="colorOnErrorContainer">@color/suisei_light_onErrorContainer</item>

        <item name="android:colorBackground">@color/suisei_light_background</item>
        <item name="colorOnBackground">@color/suisei_light_onBackground</item>
        <item name="colorSurface">@color/suisei_light_surface</item>
        <item name="colorOnSurface">@color/suisei_light_onSurface</item>
        <item name="colorSurfaceVariant">@color/suisei_light_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/suisei_light_onSurfaceVariant</item>

        <item name="colorOutline">@color/suisei_light_outline</item>
        <item name="colorOutlineVariant">@color/suisei_light_outlineVariant</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

        <item name="android:textColorPrimary">@color/suisei_light_onSurface</item>
        <item name="android:textColorSecondary">@color/suisei_light_onSurfaceVariant</item>

        <item name="toolbarStyle">@style/Widget.OTAku.Toolbar</item>
        <item name="chipStyle">@style/Widget.OTAku.Chip</item>
        <item name="materialButtonStyle">@style/Widget.OTAku.Button</item>

        <item name="colorControlNormal">@color/suisei_light_onSurface</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- Dark theme override                                           -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <style name="Theme.OTAku.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/md_theme_dark_primary</item>
        <item name="colorOnPrimary">@color/md_theme_dark_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_dark_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_dark_onPrimaryContainer</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/md_theme_dark_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_dark_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_dark_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_dark_onSecondaryContainer</item>

        <!-- Tertiary color -->
        <item name="colorTertiary">@color/md_theme_dark_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_dark_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_dark_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_dark_onTertiaryContainer</item>

        <!-- Error color -->
        <item name="colorError">@color/md_theme_dark_error</item>
        <item name="colorOnError">@color/md_theme_dark_onError</item>
        <item name="colorErrorContainer">@color/md_theme_dark_errorContainer</item>
        <item name="colorOnErrorContainer">@color/md_theme_dark_onErrorContainer</item>

        <!-- Background and surface -->
        <item name="android:colorBackground">@color/md_theme_dark_background</item>
        <item name="colorOnBackground">@color/md_theme_dark_onBackground</item>
        <item name="colorSurface">@color/md_theme_dark_surface</item>
        <item name="colorOnSurface">@color/md_theme_dark_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_dark_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_dark_onSurfaceVariant</item>

        <!-- Outline -->
        <item name="colorOutline">@color/md_theme_dark_outline</item>
        <item name="colorOutlineVariant">@color/md_theme_dark_outlineVariant</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Toolbar icon tinting -->
        <item name="colorControlNormal">@color/md_theme_dark_onSurface</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- Custom component styles                                       -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- Toolbar style -->
    <style name="Widget.OTAku.Toolbar" parent="Widget.Material3.Toolbar.Surface">
        <item name="titleTextColor">?attr/colorOnSurface</item>
        <item name="subtitleTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:background">?attr/colorSurface</item>
        <item name="elevation">2dp</item>
    </style>

    <!-- Chip style -->
    <style name="Widget.OTAku.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_default_bg</item>
        <item name="chipStrokeColor">?attr/colorOutlineVariant</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <!-- Primary button style -->
    <style name="Widget.OTAku.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Log output text view style -->
    <style name="TextAppearance.OTAku.Log" parent="TextAppearance.Material3.BodySmall">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/log_text</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
    </style>

    <!-- Section title style -->
    <style name="TextAppearance.OTAku.SectionTitle" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <!-- Body description text -->
    <style name="TextAppearance.OTAku.BodyDescription" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
    </style>

    <!-- Helper/caption text (smaller, muted) -->
    <style name="TextAppearance.OTAku.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <!-- Micro caption — even smaller than Caption.
         Used for helperText that should look like mini-info hints
         (e.g. "Leave empty for auto-generated name"). -->
    <style name="TextAppearance.OTAku.Micro" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textSize">9sp</item>
    </style>

    <!-- Label for form fields -->
    <style name="TextAppearance.OTAku.InputLabel" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>
</resources>
